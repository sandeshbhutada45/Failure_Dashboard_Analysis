HELIXGPT_API_URL=
HELIXGPT_API_KEY=

# HTTP port for the combined API + static UI (default 8080). Set PORT=80 only if appropriate for your host.
# PORT=8080

# Copy this file to .env and fill in real values. Never commit .env.
# This example intentionally has no secrets (safe to commit to git).

# Include failure screenshots from the embedded Playwright report ZIP as
# OpenAI-style multimodal parts (image_url data URLs). Set to 0 to send text only.
RCA_VISION=1

# Per failed test: max PNG/JPEG/WebP attachments read from the ZIP (default 2).
VISION_MAX_IMAGES_PER_TEST=2

# Per LLM request: max images across the whole batch (default 10).
VISION_MAX_IMAGES_PER_REQUEST=10

# Skip images larger than this many bytes (default 524288 = 512 KB).
VISION_MAX_IMAGE_BYTES=524288

# Optional: integer seed for more reproducible completions (if your API supports it).
# RCA_LLM_SEED=42

# Uploads: POST Playwright index.html (with embedded report data) and/or .json snippets.

# Max size in bytes for each uploaded report file (default 5368709120 = 5 GiB). Set lower in constrained environments.
# MAX_UPLOAD_FILE_BYTES=5368709120
